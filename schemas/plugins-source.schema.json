{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["plugins"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "author", "description", "repo", "tags"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique plugin ID (must match manifest.json id)"
          },
          "name": {
            "type": "string",
            "description": "Plugin display name"
          },
          "author": {
            "type": "string",
            "description": "Plugin author name"
          },
          "description": {
            "type": "string",
            "description": "Plugin description"
          },
          "repo": {
            "type": "string",
            "pattern": "^https://github\\.com/[^/]+/[^/]+/?$",
            "description": "GitHub repository URL"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "description": "Array of tags (e.g., [\"ui\", \"productivity\"])"
          },
          "funding_url": {
            "type": "string",
            "format": "uri",
            "description": "Optional funding/sponsorship URL"
          }
        }
      }
    }
  }
}

