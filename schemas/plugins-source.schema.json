{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["plugins"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "repo", "release_tag", "min_app_version", "tags", "author"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Plugin name (must be unique)"
          },
          "description": {
            "type": "string",
            "description": "Plugin description"
          },
          "repo": {
            "type": "string",
            "pattern": "^https://github\\.com/[^/]+/[^/]+/?$",
            "description": "GitHub repository URL"
          },
          "release_tag": {
            "type": "string",
            "pattern": "^v?\\d+\\.\\d+\\.\\d+",
            "description": "GitHub release tag (e.g., v1.0.0)"
          },
          "min_app_version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+",
            "description": "Minimum required app version (semver)"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "description": "Array of tags (e.g., [\"ui\", \"productivity\"])"
          },
          "funding_url": {
            "type": "string",
            "format": "uri",
            "description": "Optional funding/sponsorship URL"
          },
          "author": {
            "type": "string",
            "description": "Plugin author name"
          }
        }
      }
    }
  }
}

